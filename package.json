{
  "name": "anime-mcp",
  "version": "1.0.0",
  "description": "MCP server for anime search using Annict REST API",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "anime-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "dev": "tsc --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["mcp", "annict", "anime"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
